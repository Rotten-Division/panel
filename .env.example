APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_URL=http://panel.test
APP_INSTALLED=false
APP_LOCALE=en

# fork additions, see config/app.php and config/services.php for usage.
# APP_VERSION drives the plugin update channel, leave blank or set to
# canary for canary builds, set to a v prefixed tag for release builds.
# the docker workflow stamps this at image build time, local checkouts
# default to canary when unset.
APP_VERSION=

# read access token for the private Rotten-Division plugin manifest repo,
# the panel update check and per plugin manifest fetch both need it. a
# fine grained github pat scoped to read on the plugin repo is enough.
GITHUB_PLUGIN_TOKEN=

# user agent string sent on every plugin manifest fetch, defaults to
# OspiteHosting-Panel when unset.
GITHUB_PLUGIN_USER_AGENT=
